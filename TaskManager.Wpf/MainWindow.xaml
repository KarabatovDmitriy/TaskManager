<Window x:Class="TaskManager.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Менеджер задач" Height="550" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Управление задачами" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Панель инструментов -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBox x:Name="SearchBox" Width="150" Margin="0,0,5,5"
                     TextChanged="SearchBox_TextChanged"/>
            <ComboBox x:Name="StatusFilter" Width="120" Margin="0,0,5,5"
                      SelectionChanged="StatusFilter_SelectionChanged"/>
            <Button Content="Добавить" Width="80" Margin="0,0,5,5"
                    Click="AddButton_Click"/>
            <Button Content="Изменить" Width="80" Margin="0,0,5,5"
                    Click="EditButton_Click"/>
            <Button Content="Удалить" Width="80" Margin="0,0,5,5"
                    Click="DeleteButton_Click"/>
            <Button Content="Сохранить" Width="80" Margin="0,0,5,5"
                    Click="SaveButton_Click"/>
            <Button Content="Загрузить" Width="80" Margin="0,0,5,5"
                    Click="LoadButton_Click"/>
        </WrapPanel>

        <!-- Таблица задач -->
        <DataGrid x:Name="TasksGrid" Grid.Row="2" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="150"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="200"/>
                <DataGridTextColumn Header="Приоритет" Binding="{Binding Priority}" Width="80"/>
                <DataGridTextColumn Header="Срок" Binding="{Binding Deadline, StringFormat=dd.MM.yyyy}" Width="80"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Важная" Binding="{Binding IsImportant}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Статистика -->
        <StatusBar Grid.Row="3" Margin="0,5,0,0">
            <TextBlock x:Name="StatsBlock" Text="Готов к работе"/>
        </StatusBar>
    </Grid>
</Window>